rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Proyectos del portafolio:
    // - LECTURA: pública (cualquier visitante puede ver los proyectos)
    // - ESCRITURA: bloqueada desde el cliente
    //   (las escrituras del admin panel se hacen desde el mismo
    //    entorno local donde tienes la contraseña en el .env)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
